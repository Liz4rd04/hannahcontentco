# ===========================================
# Copy this file to .env.local and fill in your values
# ===========================================

# Supabase — find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Secret for signing portal cookies (generate a random 64-char string)
TOKEN_SECRET=replace-with-a-long-random-secret-string-at-least-32-chars

# Your live site URL (used for metadata, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Optional: Resend API key for contact form emails
# RESEND_API_KEY=re_...
# CONTACT_EMAIL=you@yourdomain.com
